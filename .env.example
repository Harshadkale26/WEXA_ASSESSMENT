# =============================================================================
# Monorepo — copy to .env at repo root for Docker Compose
# =============================================================================

# PostgreSQL
POSTGRES_USER=analytics
POSTGRES_PASSWORD=analytics_secret
POSTGRES_DB=analytics_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ENVIRONMENT=development
LOG_LEVEL=INFO
# Comma-separated list (not JSON)
CORS_ORIGINS=http://localhost:3000
DATABASE_URL=postgresql+asyncpg://analytics:analytics_secret@postgres:5432/analytics_db

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
