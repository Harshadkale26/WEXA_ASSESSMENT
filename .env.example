# =============================================================================
# Monorepo — copy to .env at repo root for Docker Compose
# =============================================================================

# PostgreSQL
POSTGRES_USER=analytics
POSTGRES_PASSWORD=analytics_secret
POSTGRES_DB=analytics_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
ENVIRONMENT=development
LOG_LEVEL=INFO
# Comma-separated list (not JSON)
CORS_ORIGINS=http://localhost:3000
DATABASE_URL=postgresql+asyncpg://analytics:analytics_secret@postgres:5432/analytics_db

# Event ingestion (optional overrides)
INGESTION_RATE_LIMIT_PER_MINUTE=10000
INGESTION_RATE_LIMIT_PER_KEY_PER_MINUTE=2000
INGESTION_MAX_BATCH_SIZE=500
INGESTION_CSV_MAX_BYTES=10485760
INGESTION_WEBHOOK_SIGNATURE_REQUIRED=false

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_WORKER_CONCURRENCY=4
CELERY_LOG_LEVEL=info
CELERY_BEAT_ENABLED=true

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
