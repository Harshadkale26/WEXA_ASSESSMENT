# Backend — copy to backend/.env for local (non-Docker) development

ENVIRONMENT=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgresql+asyncpg://analytics:analytics_secret@localhost:5432/analytics_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Event ingestion
INGESTION_RATE_LIMIT_PER_MINUTE=10000
INGESTION_MAX_BATCH_SIZE=500
INGESTION_CSV_MAX_BYTES=10485760

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_WORKER_CONCURRENCY=4
CELERY_LOG_LEVEL=info
CELERY_BEAT_ENABLED=true
CELERY_BEAT_HEALTH_INTERVAL_SECONDS=300
CELERY_BEAT_RETRY_FAILED_MINUTES=15
CELERY_TASK_DEFAULT_MAX_RETRIES=5
CELERY_TASK_RETRY_BACKOFF_MAX=900
